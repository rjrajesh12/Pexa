code:"  /**\n   * this DLP is to calculate report suites in dataLayer \"tools.analytics\" to be used within any property.\n   * it should be kept generic, so it could be synced in any ACDL property\n   * @type {boolean}\n   */\n  const dbgWithProdRS = !!a12r.util.dbg.debugThisRule(\"__dbgWithProdRS\"); // ONLY for testing RS related calculation/issues. a12r._dbgRules(\"__dbgWithProdRS\")\n  const useProdRS = dbgWithProdRS || (\n    _satellite._container.environment.stage === 'production' &&\n    a12r.util.getEnvironment(dl) === 'prod');\n\n  const ctx = {\n    brand: a12r.util.getBrand(dl),\n    market: a12r.util.getMarket(dl)?.toLowerCase(),\n    prefix: \"\"\n  }\n\n  ctx.brand = {\n    'bmw-motorrad': 'motorrad',\n    'rolls-royce': 'rollsroyce',\n  }[ctx.brand] || ctx.brand;\n\n  ctx.market = {\n    'gb': 'uk',\n    'it': ctx.brand === 'bmw' ? 'ita' : 'it',\n    'global': ctx.brand === 'alphabet' ? 'international' : 'global'\n  }[ctx.market] || ctx.market;\n\n  ctx.prefix = 'bmwgroup.' + a12r.util.getFirstFunctionWithNonZeroValue([\n    ({brand}) => ['alphabet'].includes(brand) && `${brand}.global.web.`,\n    ({brand}) => ['rollsroyce','alphabet','bmwm','financialservices','mybmwsf'].includes(brand) && `${brand}.global.`,\n    () => `group.global.`,\n  ], ctx);\n\n  let report_suite, marketRS, calculatedRS, testRS,\n    globalRS=ctx.prefix+'all',\n    withMarketRS = !['rollsroyce'].includes(ctx.brand);\n\n  testRS = a12r.util.getFirstFunctionWithNonZeroValue([\n    ({brand}) => ['bmwm'].includes(brand) && 'bmwgroup.group.global.test',\n    ({brand, prefix}) => ['rollsroyce','alphabet'].includes(brand) && prefix+'all.test',\n    ({prefix}) => prefix+'test',\n  ], ctx);\n\n  marketRS = withMarketRS && a12r.util.getFirstFunctionWithNonZeroValue([\n    ({brand, market}) => market && brand == 'alphabet' && `bmwgroup.${brand}.web.${market}`,\n    ({brand, market}) => brand && market && `bmwgroup.${brand}.${market}.market`,\n  ], ctx);\n\n  calculatedRS = [globalRS, marketRS].filter(Boolean).join(',')\n  report_suite = useProdRS ? calculatedRS : testRS\n\n  dl.merge(\"tools\", {\n    analytics: {\n      report_suite,\n      marketRS,\n      globalRS,\n      calculatedRS,\n      error_report_suite: testRS || \"\",\n      test_report_suite: testRS || \"\",\n    }\n  });\n  window.s?.sa(report_suite); // for compatibility with legacy rules sending events without LArch\n\n",path:"toolsSetupAA",type:"DLP"},timeout:8e3,delayNext:!0}]},{id:"RLf0d72f1ec92249438b0b4a2e6484b084",name:"TPT - CZ - AEM - Sklik - All Pages - PLR - p15r[l]",events:[{modulePath:"core/src/lib/events/domReady.js",settings:{},ruleOrder:50}],conditions:[{modulePath:"core/src/lib/conditions/subdomain.js",settings:{subdomains:[{value:"bmw.cz",valueIsRegex:!0}]},timeout:8e3}],actions:[{modulePath:"core/src/lib/actions/customCode.js",settings:{source:"https://assets.adobedtm.com/717b2dc27cb7/f6f10f796b8e/ed9981736e44/RC6bd0431a4eee474f825295c97c701b62-source.min.js",language:"javascript",isExternal:!0},timeout:8e3,delayNext:!0}]},{id:"RLf39e7b5170e7427eaa229b8bca1f3e19",name:"TPT - IN - AEM - Lotame - All Pages - PLR - p15r[l]",events:[{modulePath:"gcoe-adobe-client-data-layer/src/lib/events/datalayerPushListener.js",settings:{scope:"all",method:"specificEvent",eventKey:"pageview-cleansed"},ruleOrder:50},{modulePath:"core/src/lib/events/directCall.js",settings:{identifier:"TPT page view"},ruleOrder:50}],conditions:[{modulePath:"core/src/lib/conditions/subdomain.js",settings:{subdomains:[{value:"bmw.in",valueIsRegex:!0}]},timeout:8e3}],actions:[{modulePath:"core/src/lib/actions/customCode.js",settings:{source:"https://assets.adobedtm.com/717b2dc27cb7/f6f10f796b8e/ed9981736e44/RC663a42d753844b9fba474594cfeaef42-source.min.js",language:"javascript",isExternal:!0},timeout:8e3,delayNext:!0},{modulePath:"core/src/lib/actions/customCode.js",settings:{source:"https://assets.adobedtm.com/717b2dc27cb7/f6f10f796b8e/ed9981736e44/RCef49fe382909478abfbea9526653df93-source.min.js",lan